# Copy this file to .env, fill in local values, then run:
#   python scripts/setup_config.py

# WeChat Mini Program
WECHAT_APPID=your-wechat-appid
MINIPROGRAM_API_BASE_URL=http://127.0.0.1:17800

# Aliyun OSS used by the mini program photo upload and sync scripts
OSS_BUCKET=your-oss-bucket
OSS_ENDPOINT=your-oss-endpoint
OSS_PREFIX=attendance/photos/
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret

# Backend
SERVER_HOST=127.0.0.1
SERVER_PORT=17800
SERVER_DB_PATH=server/data/attend.duckdb
SERVER_IMPORT_XLSX=server/attendance.xlsx
SERVER_EXPORT_XLSX=server/export.xlsx
SERVER_UPDATE_XLSX=server/export.xlsx
